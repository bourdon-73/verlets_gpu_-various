[resource]
code = "shader_type canvas_item;
render_mode blend_mix;

uniform sampler2D screen_tex_frg_4 : hint_screen_texture;
uniform vec4 check_for : source_color;
uniform vec4 line_color : source_color;



void fragment() {
	vec4 n_out4p0;
// Texture2D:4
	n_out4p0 = texture(screen_tex_frg_4, SCREEN_UV);


// ColorParameter:7
	vec4 n_out7p0 = check_for;


	bool n_out10p0;
// Compare:10
	{
		bvec4 _bv = equal(n_out4p0, n_out7p0);
		n_out10p0 = any(_bv);
	}


	bool n_out16p0;
// Compare:16
	vec4 n_in16p0 = vec4(0.00000, 0.00000, 0.00000, 0.00000);
	vec4 n_in16p1 = vec4(0.00000, 0.00000, 0.00000, 0.00000);
	{
		bvec4 _bv = equal(n_in16p0, n_in16p1);
		n_out16p0 = all(_bv);
	}


	bool n_out20p0;
// Compare:20
	{
		bvec2 _bv = equal(vec2(n_out10p0 ? 1.0 : 0.0), vec2(n_out16p0 ? 1.0 : 0.0));
		n_out20p0 = all(_bv);
	}


// ColorParameter:5
	vec4 n_out5p0 = line_color;


	vec3 n_out6p0;
// If:6
	float n_in6p2 = 0.20000;
	vec3 n_in6p4 = vec3(0.00000, 0.00000, 0.00000);
	vec3 n_in6p5 = vec3(0.00000, 0.00000, 0.00000);
	if(abs(n_out4p0.x - n_out7p0.x) < n_in6p2)
	{
		n_out6p0 = vec3(n_out5p0.xyz);
	}
	else if(n_out4p0.x < n_out7p0.x)
	{
		n_out6p0 = n_in6p5;
	}
	else
	{
		n_out6p0 = n_in6p4;
	}


// Reroute:14
	vec3 n_out14p0 = n_out6p0;


// Reroute:21
	vec4 n_out21p0 = n_out5p0;


// Reroute:18
	vec4 n_out18p0 = n_out21p0;


// Reroute:19
	vec4 n_out19p0 = n_out18p0;


	vec2 n_out17p0;
// Switch:17
	n_out17p0 = mix(vec2(n_out19p0.xy), vec2(n_out14p0.xy), float(n_out20p0));


// Output:0
	COLOR.rgb = vec3(n_out17p0, 0.0);


}
"
