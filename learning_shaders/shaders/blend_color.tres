[resource]
code = "shader_type canvas_item;
render_mode blend_mix;

uniform sampler2D screen_tex_frg_8 : hint_screen_texture;
uniform vec4 line_color : source_color = vec4(0.000000, 0.000000, 0.000000, 1.000000);
uniform vec4 check_for : source_color = vec4(1.000000, 0.000000, 0.000000, 1.000000);



void fragment() {
	vec4 n_out8p0;
// Texture2D:8
	n_out8p0 = texture(screen_tex_frg_8, SCREEN_UV);


// ColorParameter:11
	vec4 n_out11p0 = line_color;


// ColorParameter:13
	vec4 n_out13p0 = check_for;


	vec3 n_out12p0;
// If:12
	float n_in12p2 = 0.20000;
	if(abs(n_out8p0.x - n_out11p0.x) < n_in12p2)
	{
		n_out12p0 = vec3(n_out13p0.xyz);
	}
	else if(n_out8p0.x < n_out11p0.x)
	{
		n_out12p0 = vec3(n_out11p0.xyz);
	}
	else
	{
		n_out12p0 = vec3(n_out11p0.xyz);
	}


// Output:0
	COLOR.rgb = n_out12p0;


}
"
